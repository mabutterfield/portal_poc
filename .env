# IP address of the FortiGate interface that sends RADIUS requests (the NAS).
# This is the IP of the guest-facing interface, e.g. v302 — NOT the WAN IP.
# From your setup: 10.252.13.254 (the interface FortiGate uses to reach the RADIUS server)
FORTIGATE_IP=10.252.13.254

# Shared secret — must match what you set on the FortiGate RADIUS server object.
SHARED_SECRET=ch4ng3m3

# Flask session encryption key — change this to a long random string.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=please-generate-a-random-string-here

# Path to the directory containing portal.crt and portal.key
CERT_PATH=./certs
